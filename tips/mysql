约束
定义主键约束（必须有，且唯一）
逻辑主键：跟业务无关 id
业务主键：跟业务有关
create table t1(
id int primary key,
name varchar(100)
);
定义主键自动增长
create table t2(
id int primary key auto_increment,
name varchar(100)
);
定义唯一约束
create table t3(
 id int primary key auto_increment,
 username varchar(30) unique
);
定义非空约束
create table t4(
 id int primary key auto_increment,
 username varchar(30) not null
);
定义外键约束(多表:多对一 多对多 一对一)
CONSTRAINT ordersid_FK FOREGIN KEY(ordersid) REFERENCES orders(id)
一对多
create table department(
 id int primary key,
 name varchar(30)
);
create table employee(
 id int primary key,
 name varchar(30),
 dept_id int,
 CONSTRAINT dept_id_FK FOREIGN KEY(dept_id) REFERENCES department(id)
);
多对多
create table teacher(
 id int primary key,
 name varchar(30),
 salary float
);
create table stu(
 id int primary key,
 name varchar(30)
);
create table teacher_stu(
 t_id int,
 s_id int,
 primary key(t_id,s_id),
 CONSTRAINT t_id_FK FOREIGN KEY(t_id) REFERENCES teacher(id),
 CONSTRAINT s_id_FK FOREIGN KEY(s_id) REFERENCES stu(id)
);
一对一
create table person(
 id int primary key,
 name varchar(30)
);
create table idcard(
 id int primary key,
 name varchar(30),
 CONSTRAINT p_id_FK FOREIGN KEY(id) REFERENCES person(id)
);